# --- Split domains (frontend and API on different URLs) ---
# Set this to your API’s public HTTPS URL (no trailing slash). Required when the Next app
# and Express API are not on the same host.
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com

# --- Same server / local dev ---
# Leave NEXT_PUBLIC_API_BASE_URL unset: the browser calls /api on the Next host and
# next.config.mjs rewrites to BACKEND_URL (see next.config.mjs).

# Server-only (Next rewrite target), not NEXT_PUBLIC:
# BACKEND_URL=http://127.0.0.1:4000
